# Upstash Redis (REST). No Vercel, estas duas variáveis são preenchidas
# automaticamente ao adicionar a integração "Upstash" pelo Marketplace.
# Para dev local você pode deixar VAZIO — o app cai num fallback em memória
# (os dados somem quando o servidor reinicia; aparece um aviso no console).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
